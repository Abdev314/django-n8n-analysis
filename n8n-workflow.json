      "name": "Respond to Webhook"
    },
    {
      "parameters": {
        "jsCode": "// Get the assistant's message content from the HTTP Request node\nconst content = $input.first().json.message.content;\n\nlet cleanText = content;\n\n// If the content contains a JSON code block, try to extract it\nconst jsonMatch = content.match(/```json\\n([\\s\\S]*?)\\n```/);\nif (jsonMatch) {\n  try {\n    const parsed = JSON.parse(jsonMatch[1]);\n    // If the JSON has an \"Analysis\" array, format it nicely\n    if (parsed.Analysis && Array.isArray(parsed.Analysis)) {\n      cleanText = parsed.Analysis.map(item => \n        `${item.Title}: ${item.Description}`\n      ).join('\\n\\n');\n    } else {\n      // Otherwise, stringify the whole parsed JSON (pretty)\n      cleanText = JSON.stringify(parsed, null, 2);\n    }\n  } catch (e) {\n    // Fallback: keep the original content\n    cleanText = content;\n  }\n}\n\n// Return the cleaned text as a string (plain text)\nreturn [{\n  json: {\n    analysisText: cleanText\n  }\n}];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
