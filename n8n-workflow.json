    {
      "parameters": {
        "jsCode": "// // Node: Transform for LLM\n// const items = $input.all();\n// return items.map(item => ({\n//   json: {\n//     chatInput: item.json.content || item.json.data || JSON.stringify(item.json)\n//   }\n// }));\n\n\n\n\n\n// Node: Transform for LLM\nconst items = $input.all();\n\nreturn items.map(item => {\n  // Extract the actual message from the Telegram Trigger or previous node\n  const rawContent = item.json.message?.text || item.json.content || JSON.stringify(item.json);\n  \n  // Clean out the \"/data\" command if it's still there\n  const cleanInput = rawContent.replace(/\\/data\\s*/i, '').trim();\n\n  return {\n    json: {\n      // We add a 'system_instruction' to the prompt to force plain text\n      chatInput: `System: Reply in plain text only. Do not use Markdown, bold (*), or italics (_). \\n\\nUser Question: ${cleanInput}`\n    }\n  };\n});"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
